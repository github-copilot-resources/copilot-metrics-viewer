# Dockerfile for standalone sync job
# This creates a lightweight container that only runs the sync service
# Use this for Kubernetes CronJobs or scheduled container instances

FROM node:20-alpine AS base

# Install dependencies only when needed
FROM base AS deps
WORKDIR /app

# Copy package files
COPY package.json package-lock.json ./
RUN npm ci

# Build stage - compile TypeScript
FROM base AS builder
WORKDIR /app

COPY package.json package-lock.json ./
COPY nuxt.config.ts tsconfig.json ./
RUN npm ci

# Copy source code
COPY server ./server
COPY shared ./shared
COPY app/model ./app/model
COPY app/types ./app/types
COPY app/utils ./app/utils

# Compile TypeScript to JavaScript
RUN npx tsc server/sync-entry.ts --outDir ./dist --module commonjs --esModuleInterop --skipLibCheck --resolveJsonModule

# Production stage
FROM base AS runner
WORKDIR /app

ENV NODE_ENV=production

# Copy production dependencies only
COPY package.json package-lock.json ./
RUN npm ci --production --ignore-scripts

# Copy compiled sync entry and source files
COPY --from=builder /app/dist ./dist
COPY --from=builder /app/server ./server
COPY --from=builder /app/shared ./shared
COPY --from=builder /app/app/model ./app/model
COPY --from=builder /app/app/types ./app/types
COPY --from=builder /app/app/utils ./app/utils

# Create data directory for filesystem storage
RUN mkdir -p ./.data/metrics && chown -R node:node ./.data

USER node

# Run compiled sync entry point
CMD ["node", "dist/server/sync-entry.js"]
